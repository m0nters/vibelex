{
  "name": "vite-extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run i18n:check && npm run test:verbose && vite build && node build-postprocess.mjs",
    "quick-build": "tsc -b && vite build && node build-postprocess.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "i18n:check": "i18n-check -l public/locales -s en -f i18next -u src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:verbose": "vitest run --reporter=tree",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.13",
    "flag-icons": "^7.5.0",
    "fuse.js": "^7.1.0",
    "html-to-image": "^1.11.13",
    "i18next": "^25.5.2",
    "i18next-http-backend": "^3.0.2",
    "jsonrepair": "^3.13.1",
    "lucide-react": "^0.542.0",
    "markdown-to-jsx": "^7.7.13",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.7.3",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.8.2",
    "recharts": "^3.4.1",
    "tailwindcss": "^4.1.13",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@lingual/i18n-check": "^0.8.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tsx": "^4.20.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^4.1.0"
  }
}
